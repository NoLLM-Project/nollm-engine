{
  "identity": {
    "unique_ids": true,
    "valid_parent_required": true,
    "no_self_in_children": true,
    "no_self_in_adjacent": true
  },
  "hierarchy": {
    "world_children": ["world"],
    "hotel_requires_root": "coord_hotel_root",
    "floor_requires_root": "coord_hotel_root",
    "room_requires_parent_type": "floor",
    "abstract_disallowed_under_spatial": true
  },
  "spatial": {
    "z_monotonic_floors": true,
    "rooms_share_floor_z": true,
    "hallways_share_floor_z": true,
    "vertical_circulation_match_floors": true
  },
  "adjacency": {
    "bidirectional": true,
    "disallow_parent": true,
    "disallow_children": true,
    "disallow_self": true,
    "rules_file": "adjacency_rules.json"
  },
  "abstract": {
    "xyz_null": true,
    "no_spatial_adjacency": true,
    "only_adjacent_to_abstract": true
  },
  "routing": {
    "vertical_sequence_required": true,
    "hallways_same_floor": true,
    "rooms_to_hallways_only": true
  },
  "integrity": {
    "no_cycles": true,
    "world_connected_root": "coord_world_root",
    "hotel_connected_root": "coord_hotel_root",
    "floor_stack_continuous": true
  }
}
