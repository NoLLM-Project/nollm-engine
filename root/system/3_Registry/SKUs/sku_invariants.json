{
  "identity": {
    "global_uniqueness": true,
    "stable_sku": true,
    "required_fields": [
      "object_id",
      "coordinates",
      "metadata",
      "category",
      "version"
    ]
  },

  "object_mapping": {
    "object_id_must_exist_in_canonical_names": true,
    "coordinates_must_exist_in_coordinate_registry": true,
    "metadata_must_exist_in_metadata_registry": true,
    "category_must_match_true_type": true
  },

  "category_invariants": {
    "world_plane": ["container"],
    "hotel_plane": ["container"],
    "room_plane": ["container"],
    "circulation_plane": ["circulation"],
    "module_plane": ["module"],
    "validator_plane": ["validator"],
    "ui_plane": [
      "ui",
      "ui_edge",
      "ui_layer",
      "ui_style",
      "ui_animation",
      "ui_error",
      "ui_scene",
      "ui_transition",
      "ui_interaction",
      "ui_state_machine",
      "ui_accessibility"
    ]
  },

  "coordinate_invariants": {
    "spatial_objects_require_numeric_coordinates": true,
    "abstract_objects_require_null_xyz": true
  },

  "metadata_invariants": {
    "metadata_id_must_exist": true,
    "metadata_must_match_category": true,
    "metadata_must_not_contradict_identity": true
  },

  "versioning": {
    "pattern": "v<number>",
    "monotonic": true,
    "no_reuse": true
  },

  "integrity": {
    "no_orphan_skus": true,
    "no_nonexistent_references": true,
    "no_duplicate_coordinate_object_pairs": true,
    "no_violation_of_naming_or_coordinate_invariants": true
  },

  "enforcement": {
    "validate_on": [
      "startup",
      "registry_updates",
      "world_updates",
      "module_loading"
    ],
    "reject_on_violation": true
  }
}
