{
  "identity": {
    "unique_placement_ids": true,
    "unique_object_ids": true
  },

  "structural": {
    "allowed_parents_enforced": true,
    "allowed_children_enforced": true
  },

  "constraints": {
    "must_be_inside_enforced": true,
    "cannot_be_inside_enforced": true,
    "must_be_adjacent_to_enforced": true,
    "cannot_be_adjacent_to_enforced": true,
    "no_contradictory_inside_rules": true,
    "no_contradictory_adjacent_rules": true
  },

  "invariants": {
    "invariant_references_must_exist": true,
    "invariant_names_must_be_unique": true
  },

  "integrity": {
    "no_duplicate_parent_child_pairs": true,
    "no_duplicate_inside_relations": true,
    "no_duplicate_adjacent_relations": true
  }
}
